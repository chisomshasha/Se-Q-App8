    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

  <!-- Shield outline -->
  <path
      android:fillColor="#FFFFFF"
      android:pathData="M12,1 L3,5 L3,11 C3,16.55 6.84,21.74 12,23
                        C17.16,21.74 21,16.55 21,11 L21,5 Z
                        M12,3.18 L19,6.3 L19,11
                        C19,15.5 15.97,19.69 12,21.17
                        C8.03,19.69 5,15.5 5,11 L5,6.3 Z"/>

  <!-- Exclamation mark inside shield -->
  <path
      android:fillColor="#FFFFFF"
      android:pathData="M11,7 L13,7 L13,13 L11,13 Z"/>
  <path
      android:fillColor="#FFFFFF"
      android:pathData="M11,15 L13,15 L13,17 L11,17 Z"/>

</vector>
